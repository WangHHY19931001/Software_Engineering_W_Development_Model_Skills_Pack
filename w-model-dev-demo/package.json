{
  "name": "blog-system-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "博客系统后端 - W 模型端到端调测产物",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "test": "cross-env JWT_SECRET=test-secret-blog-demo vitest run",
    "test:unit": "cross-env JWT_SECRET=test-secret-blog-demo vitest run tests/unit",
    "test:integration": "cross-env JWT_SECRET=test-secret-blog-demo vitest run tests/integration",
    "test:system": "cross-env JWT_SECRET=test-secret-blog-demo vitest run tests/system",
    "test:acceptance": "cross-env JWT_SECRET=test-secret-blog-demo vitest run tests/acceptance",
    "coverage": "cross-env JWT_SECRET=test-secret-blog-demo vitest run --coverage"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/supertest": "^7.2.1",
    "@vitest/coverage-v8": "^1.6.0",
    "cross-env": "^7.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
