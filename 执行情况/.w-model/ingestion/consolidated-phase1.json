{
  "phase": 1,
  "nodes": [
    {
      "id": "REQ-001",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Shell Agent 系统",
      "summary": "Shell Agent 是以终端为主要运行环境的自主型任务智能体系统。可审计、可恢复、可约束、可验证。"
    },
    {
      "id": "REQ-002",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "接受自然语言任务目标",
      "summary": "系统应接受简短自然语言任务目标，并将其结构化为用户意图。"
    },
    {
      "id": "REQ-003",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "自主探索与信息收集",
      "summary": "系统应能在工作区和允许的外部环境中自主探索可用信息。"
    },
    {
      "id": "REQ-004",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "目标规划与步骤分解",
      "summary": "系统应将任务目标转化为可执行、可验证、可恢复的步骤结构。"
    },
    {
      "id": "REQ-005",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "受控环境任务执行",
      "summary": "系统应在受控工具执行环境中完成文件操作、Shell 执行、网络检索等。"
    },
    {
      "id": "REQ-006",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "结果验证与质量评判",
      "summary": "系统应使用确定性验证与开放性质量评判共同确认结果质量。"
    },
    {
      "id": "REQ-007",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "反思与偏差纠正",
      "summary": "系统应在每轮执行后基于状态、证据、风险、预算和质量信号进行结构化反思。"
    },
    {
      "id": "REQ-008",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "审批与澄清请求",
      "summary": "在存在关键歧义、高风险外部副作用或边界冲突时，系统应暂停并向用户请求澄清或审批。"
    },
    {
      "id": "REQ-009",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "中断恢复与可追踪性",
      "summary": "系统在任务中断、失败或环境变化后，应维持可恢复性和可追踪性。"
    },
    {
      "id": "REQ-010",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "自主任务闭环主循环",
      "summary": "系统核心是 Observe → Orient → Plan → Act → Artifact Quality Gate → Verify → Reflect 主循环。"
    },
    {
      "id": "REQ-011",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Observe 阶段",
      "summary": "系统收集与当前任务相关的环境事实。"
    },
    {
      "id": "REQ-012",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Orient 阶段",
      "summary": "系统根据观察结果形成任务理解。"
    },
    {
      "id": "REQ-013",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Plan 阶段",
      "summary": "系统把目标转化为可执行结构。"
    },
    {
      "id": "REQ-014",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Act 阶段",
      "summary": "系统通过受治理的能力入口推进任务。"
    },
    {
      "id": "REQ-015",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Verify 阶段",
      "summary": "系统根据动作产物和环境状态收集证据，判断步骤完成状态。"
    },
    {
      "id": "REQ-016",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Reflect 阶段",
      "summary": "系统根据验证结果做结构化决策。"
    },
    {
      "id": "REQ-017",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "上下文系统（Context System）",
      "summary": "负责向运行时提供足够信息，使 Agent 在长任务中保持连续性。"
    },
    {
      "id": "REQ-018",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "规划系统（Planning System）",
      "summary": "负责把模糊任务转化为可执行结构。"
    },
    {
      "id": "REQ-019",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "统一导航系统（Unified Navigation）",
      "summary": "提供统一树状视图表示能力目录、代理目录、MCP 目录等。"
    },
    {
      "id": "REQ-020",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "能力系统（Capability System）",
      "summary": "负责文件、Shell、网络、上下文管理、导出等能力族。"
    },
    {
      "id": "REQ-021",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "知识图谱系统（Knowledge Graph）",
      "summary": "负责结构化知识沉淀、查询与关系遍历。"
    },
    {
      "id": "REQ-022",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "A2A 协调系统（A2A Coordination）",
      "summary": "负责 agent 的发现、注册、寻址、路由、委派结果回收。"
    },
    {
      "id": "REQ-023",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "治理系统（Governance System）",
      "summary": "负责 Hook/Judge/Monitor 三级治理，并承载 Artifact Quality Pipeline。"
    },
    {
      "id": "REQ-024",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "一级确定性 Hook",
      "summary": "阻塞式确定性产物边界。检查 schema、必填字段、安全边界等。"
    },
    {
      "id": "REQ-025",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "二级 LLM Verifier",
      "summary": "一级通过后评估开放性质量。输出结构化评分、置信度、缺陷列表。"
    },
    {
      "id": "REQ-026",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Monitor 监控",
      "summary": "监控 token/步骤预算、循环/停滞/死锁/熔断/恢复。"
    },
    {
      "id": "REQ-027",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "严重度处置模型",
      "summary": "缺陷严重度分为 S0-S4。Quality Gate Decision 考虑最高严重度等。"
    },
    {
      "id": "REQ-028",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "产物生命周期与返工闭环",
      "summary": "正式产物状态机：Draft → DeterministicChecking → SemanticVerifying → 决策。"
    },
    {
      "id": "REQ-029",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "快照/导出/恢复系统",
      "summary": "支持中断恢复、状态迁移和事后审计。"
    },
    {
      "id": "REQ-030",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "观测/训练/持续改进系统",
      "summary": "记录和导出任务轨迹、动作结果、产物门禁等观测资产。"
    },
    {
      "id": "REQ-031",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "派生规格系统（Derived Specification System）",
      "summary": "由设计事实单向派生行为规格、接口契约和测试设计。"
    },
    {
      "id": "REQ-032",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "行为规格（Behavior Specification）",
      "summary": "采用独立 feature 文件建模系统行为。"
    },
    {
      "id": "REQ-033",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "接口契约派生（Interface Contract Derivation）",
      "summary": "接口设计由设计事实与行为规格共同派生，采用 OpenAPI 格式。"
    },
    {
      "id": "REQ-034",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "测试设计派生（Test Design Derivation）",
      "summary": "测试设计以设计事实、行为规格和接口契约为上游输入。"
    },
    {
      "id": "REQ-035",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "代理协作（Agent Collaboration）",
      "summary": "主 Agent 可将子任务委派给子 Agent 或远程 Agent。"
    },
    {
      "id": "REQ-036",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "多 Agent 产物门禁",
      "summary": "协作各环节须执行显式检查。"
    },
    {
      "id": "REQ-037",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "故障隔离与并发一致性",
      "summary": "单个子 Agent 失败不污染已通过门禁的 sibling 产物。"
    },
    {
      "id": "REQ-038",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "MCP 外部能力接入",
      "summary": "MCP 系统接入外部工具提供者。"
    },
    {
      "id": "REQ-039",
      "type": "REQ",
      "phase": 1,
      "reqType": "功能需求",
      "title": "Skill 系统行为增强",
      "summary": "Skill 是运行时中的行为增强对象。"
    },
    {
      "id": "REQ-040",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "路径与环境安全边界",
      "summary": "系统须明确工作区边界和临时执行边界。"
    },
    {
      "id": "REQ-041",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "动作风险安全边界",
      "summary": "删除不可恢复数据、工作区外写入等须视为高风险。"
    },
    {
      "id": "REQ-042",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "模型信任边界",
      "summary": "模型输出不直接视为事实，模型文本不替代审批。"
    },
    {
      "id": "REQ-043",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "延迟与超时约束",
      "summary": "每个能力调用须有超时上限并产生结构化 timeout 终态。"
    },
    {
      "id": "REQ-044",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "并发与吞吐约束",
      "summary": "同时活跃的子 Agent 数量须有上限。"
    },
    {
      "id": "REQ-045",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "可用性与恢复约束",
      "summary": "单个外部服务不可用时须能降级或产生明确 blocked 等待态。"
    },
    {
      "id": "REQ-046",
      "type": "REQ",
      "phase": 1,
      "reqType": "非功能需求",
      "title": "边界条件与极端输入约束",
      "summary": "空目标/空 Task Graph/空产物须产生 invalid_request 错误。"
    },
    {
      "id": "REQ-047",
      "type": "REQ",
      "phase": 1,
      "reqType": "约束需求",
      "title": "非目标约束：非无边界通用执行器",
      "summary": "Shell Agent 不应成为无边界的通用操作系统控制器。"
    },
    {
      "id": "REQ-048",
      "type": "REQ",
      "phase": 1,
      "reqType": "约束需求",
      "title": "上下文边界原则",
      "summary": "工作区和临时目录外访问须边界控制。"
    },
    {
      "id": "REQ-049",
      "type": "REQ",
      "phase": 1,
      "reqType": "约束需求",
      "title": "设计事实唯一性约束",
      "summary": "DESIGN.md 是唯一设计事实来源。"
    },
    {
      "id": "REQ-050",
      "type": "REQ",
      "phase": 1,
      "reqType": "约束需求",
      "title": "主循环设计约束",
      "summary": "无观察依据不得直接进入高副作用执行。"
    },
    {
      "id": "EXT-IN-001",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "用户输入",
      "summary": "用户通过 CLI/REPL 提供的自然语言任务目标、审批响应和澄清答复。"
    },
    {
      "id": "EXT-IN-002",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "工作区文件系统",
      "summary": "Shell Agent 工作区中的文件、目录结构及其内容。"
    },
    {
      "id": "EXT-IN-003",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "Shell 执行环境",
      "summary": "受限 Shell 执行环境，提供命令执行能力及退出码/输出结果。"
    },
    {
      "id": "EXT-IN-004",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "Web 信息源",
      "summary": "外部 Web 信息源，提供网页内容搜索和检索能力。"
    },
    {
      "id": "EXT-IN-005",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "MCP 服务",
      "summary": "外部 MCP 协议服务，提供第三方工具能力发现和调用。"
    },
    {
      "id": "EXT-IN-006",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "A2A 远程代理",
      "summary": "通过 A2A 协议接入的远程代理节点。"
    },
    {
      "id": "EXT-IN-007",
      "type": "EXT-IN",
      "phase": 1,
      "reqType": "边界节点",
      "title": "模型服务",
      "summary": "LLM/Embedding/Judge 等模型服务。"
    },
    {
      "id": "EXT-OUT-001",
      "type": "EXT-OUT",
      "phase": 1,
      "reqType": "边界节点",
      "title": "用户汇报",
      "summary": "系统向用户输出的执行结果汇报、澄清请求和审批请求。"
    },
    {
      "id": "EXT-OUT-002",
      "type": "EXT-OUT",
      "phase": 1,
      "reqType": "边界节点",
      "title": "工作区文件写入",
      "summary": "系统对工作区文件系统的写入、修改和创建操作结果。"
    },
    {
      "id": "EXT-OUT-003",
      "type": "EXT-OUT",
      "phase": 1,
      "reqType": "边界节点",
      "title": "Shell 命令执行结果",
      "summary": "系统通过受限 Shell 环境执行命令产生的输出、退出码和副作用。"
    },
    {
      "id": "EXT-OUT-004",
      "type": "EXT-OUT",
      "phase": 1,
      "reqType": "边界节点",
      "title": "网络请求",
      "summary": "系统向外部 Web 发起的搜索和网页内容获取请求。"
    },
    {
      "id": "EXT-OUT-005",
      "type": "EXT-OUT",
      "phase": 1,
      "reqType": "边界节点",
      "title": "派生规格资产",
      "summary": "由设计事实派生的行为规格、接口契约和测试设计等正式规格资产。"
    },
    {
      "id": "EXT-OUT-006",
      "type": "EXT-OUT",
      "phase": 1,
      "reqType": "边界节点",
      "title": "观测/训练数据输出",
      "summary": "系统产生的任务轨迹、产物门禁记录、Verifier 评分等观测资产。"
    }
  ],
